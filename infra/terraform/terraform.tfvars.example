# Copy this file to terraform.tfvars and fill in values.
# terraform.tfvars is gitignored — never commit actual secrets.

resource_group_name = "maison-aura-rg"
location            = "southeastasia"
acr_name            = "maisonauraacr"
aks_cluster_name    = "maison-aura-aks"
key_vault_name      = "maisonaura-kv"
node_count          = 2
node_vm_size        = "Standard_B2s"

stripe_secret_key               = ""
stripe_webhook_secret           = ""
db_server                       = "khalisserver.database.windows.net"
db_name                         = "khalisserver"
db_user                         = ""
db_password                     = ""
admin_email                     = ""
admin_password                  = ""
admin_secret                    = ""
azure_storage_connection_string = ""
azure_storage_container         = "product-images"
